{
  "info": {
    "name": "Module 2 — Client Credentials (Salesforce + Auth0)",
    "description": "Two folders, run top to bottom:\n\n1. 'Inbound — Salesforce': Postman plays the external system calling INTO Salesforce (token → smoke test → query → create).\n2. 'Project — Auth0 CRUD': the mini-project's Session A — full create/read/update/delete against the Auth0 Management API.\n\nSET THESE COLLECTION VARIABLES FIRST (Collection > Variables tab):\n- my_domain: your org's My Domain URL, e.g. https://yourcompany.my.salesforce.com (NOT login.salesforce.com)\n- consumer_key / consumer_secret: from the External Client App (Settings > OAuth Settings > Consumer Key and Secret)\n- auth0_domain: your tenant domain WITHOUT https://, e.g. dev-abc123.us.auth0.com\n- auth0_client_id / auth0_client_secret: from the Auth0 M2M application's Settings tab\n\nToken requests auto-save their tokens; the Auth0 create request auto-saves the new user's id.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "my_domain", "value": "https://YOURCOMPANY.my.salesforce.com", "type": "string" },
    { "key": "consumer_key", "value": "PASTE_CONSUMER_KEY", "type": "string" },
    { "key": "consumer_secret", "value": "PASTE_CONSUMER_SECRET", "type": "string" },
    { "key": "api_version", "value": "64.0", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "auth0_domain", "value": "dev-REPLACE.us.auth0.com", "type": "string" },
    { "key": "auth0_client_id", "value": "PASTE_AUTH0_CLIENT_ID", "type": "string" },
    { "key": "auth0_client_secret", "value": "PASTE_AUTH0_CLIENT_SECRET", "type": "string" },
    { "key": "auth0_access_token", "value": "", "type": "string" },
    { "key": "auth0_user_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Inbound — Salesforce",
      "description": "Postman as the external system calling into Salesforce via the client credentials flow. Requires the ECA + Run As setup from the guide (Module 2, topics 2–3).",
      "item": [
        {
          "name": "1. Get Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('access_token', pm.response.json().access_token);",
                  "    console.log('Salesforce access token saved.');",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access_token', () => pm.expect(pm.response.json()).to.have.property('access_token'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials", "type": "text" },
                { "key": "client_id", "value": "{{consumer_key}}", "type": "text" },
                { "key": "client_secret", "value": "{{consumer_secret}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{my_domain}}/services/oauth2/token",
              "host": ["{{my_domain}}"],
              "path": ["services", "oauth2", "token"]
            },
            "description": "Must use the My Domain URL. Note the response has NO refresh token — by design; just run this again when the token expires."
          }
        },
        {
          "name": "2. Smoke Test — List API Versions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{my_domain}}/services/data/",
              "host": ["{{my_domain}}"],
              "path": ["services", "data", ""]
            },
            "description": "If this returns 200 your token works. Update the api_version variable to the newest listed."
          }
        },
        {
          "name": "3. SOQL Query — Accounts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{my_domain}}/services/data/v{{api_version}}/query?q=SELECT Id, Name FROM Account LIMIT 5",
              "host": ["{{my_domain}}"],
              "path": ["services", "data", "v{{api_version}}", "query"],
              "query": [{ "key": "q", "value": "SELECT Id, Name FROM Account LIMIT 5" }]
            },
            "description": "You only see what the Run As user can see — permissions enforced live."
          }
        },
        {
          "name": "4. Create an Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Name\": \"Module 2 Integration Test\",\n  \"Industry\": \"Technology\"\n}"
            },
            "url": {
              "raw": "{{my_domain}}/services/data/v{{api_version}}/sobjects/Account",
              "host": ["{{my_domain}}"],
              "path": ["services", "data", "v{{api_version}}", "sobjects", "Account"]
            },
            "description": "Expect 201 Created. Open the record in Salesforce: Created By = your integration user."
          }
        }
      ]
    },
    {
      "name": "Project — Auth0 CRUD",
      "description": "Mini-project Session A: prove all four CRUD verbs against the Auth0 Management API before configuring Salesforce. Set auth0_domain / auth0_client_id / auth0_client_secret first.",
      "item": [
        {
          "name": "1. Get Token (note the audience parameter!)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('auth0_access_token', json.access_token);",
                  "    console.log('Auth0 token saved. Lives ' + json.expires_in + ' seconds (24h default).');",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials", "type": "text" },
                { "key": "client_id", "value": "{{auth0_client_id}}", "type": "text" },
                { "key": "client_secret", "value": "{{auth0_client_secret}}", "type": "text" },
                { "key": "audience", "value": "https://{{auth0_domain}}/api/v2/", "type": "text" }
              ]
            },
            "url": {
              "raw": "https://{{auth0_domain}}/oauth/token",
              "protocol": "https",
              "host": ["{{auth0_domain}}"],
              "path": ["oauth", "token"]
            },
            "description": "Same grant_type as the Salesforce request — plus Auth0's twist: 'audience' names WHICH API the token is for (the Management API, trailing slash included). Break-it drill: remove audience and watch it fail."
          }
        },
        {
          "name": "2. CREATE user (POST)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('auth0_user_id', pm.response.json().user_id);",
                  "    console.log('Created user id saved: ' + pm.response.json().user_id);",
                  "}",
                  "pm.test('Status is 201 Created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth0_access_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jamal.test@example.com\",\n  \"password\": \"TrainingP@ssw0rd2026!\",\n  \"connection\": \"Username-Password-Authentication\"\n}"
            },
            "url": {
              "raw": "https://{{auth0_domain}}/api/v2/users",
              "protocol": "https",
              "host": ["{{auth0_domain}}"],
              "path": ["api", "v2", "users"]
            },
            "description": "'connection' = which user database the account lives in; Username-Password-Authentication is every tenant's default. Check Auth0 Dashboard > User Management > Users after running."
          }
        },
        {
          "name": "3. READ user (GET)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth0_access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "https://{{auth0_domain}}/api/v2/users/{{auth0_user_id}}",
              "protocol": "https",
              "host": ["{{auth0_domain}}"],
              "path": ["api", "v2", "users", "{{auth0_user_id}}"]
            },
            "description": "Reads the user created in request 2 (its id was auto-saved)."
          }
        },
        {
          "name": "4. UPDATE user (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth0_access_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_metadata\": { \"plan\": \"gold\" }\n}"
            },
            "url": {
              "raw": "https://{{auth0_domain}}/api/v2/users/{{auth0_user_id}}",
              "protocol": "https",
              "host": ["{{auth0_domain}}"],
              "path": ["api", "v2", "users", "{{auth0_user_id}}"]
            },
            "description": "user_metadata is Auth0's 'custom fields' bucket. Expect 200 with the updated user echoed back."
          }
        },
        {
          "name": "5. DELETE user (DELETE)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth0_access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "https://{{auth0_domain}}/api/v2/users/{{auth0_user_id}}",
              "protocol": "https",
              "host": ["{{auth0_domain}}"],
              "path": ["api", "v2", "users", "{{auth0_user_id}}"]
            },
            "description": "Expect 204 No Content — success with an empty body. Run it twice to meet the 404 (deleting something already gone is a state to expect, not a bug)."
          }
        }
      ]
    }
  ]
}
